{% extends 'base.html.twig' %}
{% block title %}Catégories du portail{% endblock %}
{% block body %}
<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="h3 mb-1"><i class="fas fa-folder-open me-2"></i>Catégories du portail</h1>
            <a href="{{ path('admin_portail_index') }}"><i class="fas fa-arrow-left me-1"></i>Retour aux tuiles</a>
        </div>
        <a href="{{ path('admin_portail_categorie_new') }}" class="btn btn-success">
            <i class="fas fa-plus me-1"></i>Nouvelle catégorie
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="text-center" style="width:70px;">Ordre</th>
                        <th style="width:60px;"></th>
                        <th>Nom</th>
                        <th class="text-center">Applications</th>
                        <th class="text-center">Statut</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for category in categories %}
                        <tr>
                            <td class="text-center">
                                <span class="badge bg-secondary">{{ category.position }}</span>
                            </td>
                            <td class="text-center">
                                {% if category.icone %}
                                    <i class="{{ category.icone }} fa-lg" style="color: {{ category.couleur ?: '#800000' }};"></i>
                                {% else %}
                                    <span class="d-inline-block rounded-circle" style="width:14px;height:14px;background:{{ category.couleur ?: '#ccc' }};"></span>
                                {% endif %}
                            </td>
                            <td class="fw-semibold">{{ category.nom }}</td>
                            <td class="text-center">
                                <span class="badge bg-info text-dark">{{ category.tiles|length }}</span>
                            </td>
                            <td class="text-center">
                                {% if category.actif %}
                                    <span class="badge bg-success"><i class="fas fa-eye me-1"></i>Visible</span>
                                {% else %}
                                    <span class="badge bg-secondary"><i class="fas fa-eye-slash me-1"></i>Masquée</span>
                                {% endif %}
                            </td>
                            <td class="text-end">
                                <a href="{{ path('admin_portail_categorie_edit', {id: category.id}) }}" class="btn btn-primary btn-sm">
                                    <i class="fas fa-pen"></i>
                                </a>
                                <form method="post" action="{{ path('admin_portail_categorie_delete', {id: category.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer cette catégorie ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
                                    <button class="btn btn-danger btn-sm"
                                        {% if category.tiles|length > 0 %}disabled title="Des applications sont rattachées à cette catégorie"{% endif %}>
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                                Aucune catégorie pour le moment
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}

{% extends 'base.html.twig' %}
{% form_theme form 'bootstrap_5_layout.html.twig' %}
{% block title %}Modifier la catégorie{% endblock %}
{% block body %}
<div class="container mt-4 mb-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin_portail_index') }}">Portail</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin_portail_categorie_index') }}">Catégories</a></li>
            <li class="breadcrumb-item active">{{ category.nom }}</li>
        </ol>
    </nav>

    <div class="card shadow-sm">
        <div class="card-header bg-white">
            <h1 class="h4 mb-0"><i class="fas fa-pen text-primary me-2"></i>Modifier : {{ category.nom }}</h1>
        </div>
        <div class="card-body">
            {{ form_start(form) }}
                <div class="row g-3">
                    <div class="col-md-8">{{ form_row(form.nom) }}</div>
                    <div class="col-md-4">{{ form_row(form.position) }}</div>

                    <div class="col-md-6">{{ form_row(form.icone) }}</div>
                    <div class="col-md-6">
                        {% include 'admin/portail/_couleur_picker.html.twig' with {field: form.couleur} %}
                    </div>

                    <div class="col-12">
                        <div class="form-check form-switch mt-2">
                            {{ form_widget(form.actif) }}
                            {{ form_label(form.actif) }}
                        </div>
                    </div>
                </div>

                <hr class="my-4">
                <button class="btn btn-success"><i class="fas fa-check me-1"></i>Enregistrer</button>
                <a href="{{ path('admin_portail_categorie_index') }}" class="btn btn-outline-secondary">Annuler</a>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}

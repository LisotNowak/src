{% extends 'base.html.twig' %}
{% block title %}Administration Portail{% endblock %}
{% block body %}
<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="h3 mb-1"><i class="fas fa-th-large me-2"></i>Gestion du portail applicatif</h1>
        </div>
        <div>
            <a href="{{ path('admin_portail_categorie_index') }}" class="btn btn-outline-secondary">
                <i class="fas fa-folder-open me-1"></i>Catégories
            </a>
            <a href="{{ path('admin_portail_new') }}" class="btn btn-success">
                <i class="fas fa-plus me-1"></i>Nouvelle tuile
            </a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="text-center" style="width:70px;">Ordre</th>
                        <th style="width:60px;"></th>
                        <th>Titre</th>
                        <th>Catégorie</th>
                        <th>Lien</th>
                        <th class="text-center">Statut</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for tile in tiles %}
                        <tr>
                            <td class="text-center">
                                <span class="badge bg-secondary">{{ tile.position }}</span>
                            </td>
                            <td class="text-center">
                                {% if tile.icone %}
                                    <i class="{{ tile.icone }} fa-lg" style="color: {{ tile.couleur ?: '#800000' }};"></i>
                                {% else %}
                                    <span class="d-inline-block rounded-circle" style="width:14px;height:14px;background:{{ tile.couleur ?: '#ccc' }};"></span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="fw-semibold">{{ tile.titre }}</div>
                                {% if tile.description %}
                                    <div class="text-muted small">{{ tile.description }}</div>
                                {% endif %}
                            </td>
                            <td>
                                <span class="badge" style="background-color: {{ tile.categorie.couleur ?: '#6c757d' }};">
                                    {{ tile.categorie.nom }}
                                </span>
                            </td>
                            <td>
                                <code class="small">{{ tile.url }}</code>
                                {% if tile.nouvelOnglet %}
                                    <i class="fas fa-external-link-alt text-muted ms-1" title="Ouvre dans un nouvel onglet"></i>
                                {% endif %}
                            </td>
                            <td class="text-center">
                                {% if tile.actif %}
                                    <span class="badge bg-success"><i class="fas fa-eye me-1"></i>Visible</span>
                                {% else %}
                                    <span class="badge bg-secondary"><i class="fas fa-eye-slash me-1"></i>Masquée</span>
                                {% endif %}
                            </td>
                            <td class="text-end">
                                <a href="{{ path('admin_portail_edit', {id: tile.id}) }}" class="btn btn-primary btn-sm">
                                    <i class="fas fa-pen"></i>
                                </a>
                                <form method="post" action="{{ path('admin_portail_delete', {id: tile.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer cette tuile ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tile.id) }}">
                                    <button class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                                Aucune tuile pour le moment
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}

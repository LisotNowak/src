                <td><input id="jeudiHSaisie" type="number" class="form-control HSaisie" onKeyUp="calcul()"></td>
                <td><input id="jeudiHNorm" type="number" class="form-control HNorm" disabled></td>
                <td><input id="jeudiHRepComp" type="number" class="form-control HRepComp" disabled></td>
                <td><input id="jeudiHCompl" type="number" class="form-control HCompl" disabled></td>
                <td><input id="jeudiHS10" type="number" class="form-control" disabled></td>
                <td><input id="jeudiHRepComp10" type="number" class="form-control" disabled></td>
                <td><input id="jeudiHS25" type="number" class="form-control HS25" disabled></td>
                <td><input id="jeudiHRepComp25" type="number" class="form-control" disabled></td>
                <td><input id="jeudiHS50" type="number" class="form-control HS50" disabled></td>
                <td><input id="jeudiHRepComp50" type="number" class="form-control" disabled></td>
                <td><input id="jeudiHS100" type="number" class="form-control" disabled></td>
                <td><input id="jeudiHRepComp100" type="number" class="form-control" disabled></td>

                <td><input id="samediHS100" type="number" class="form-control" disabled></td>
                <td><input id="samediHRepComp100" type="number" class="form-control" disabled></td>
                <td><input id="samediRTT" type="number" class="form-control" disabled></td>
            </tr>
            <tr>
                <td style="white-space: nowrap;">Dimanche</td>
                <td><input id="dimancheHSaisie" type="number" class="form-control HSaisie dimancheHSaisie" onKeyUp="calcul()"></td>
                <td><input id="dimancheHNorm" type="number" class="form-control HNorm" disabled></td>
                <td><input id="dimancheHRepComp" type="number" class="form-control HRepComp" disabled></td>
                <td><input id="dimancheHCompl" type="number" class="form-control HCompl" disabled></td>
                <td><input id="dimancheHS10" type="number" class="form-control" disabled></td>
                <td><input id="dimancheHRepComp10" type="number" class="form-control" disabled></td>
                <td><input id="dimancheHS25" type="number" class="form-control HS25" disabled></td>
                <td><input id="dimancheHRepComp25" type="number" class="form-control" disabled></td>
                <td><input id="dimancheHS50" type="number" class="form-control HS50" disabled></td>
                <td><input id="dimancheHRepComp50" type="number" class="form-control" disabled></td>
                <td><input id="dimancheHS100" type="number" class="form-control" disabled></td>
                <td><input id="dimancheHRepComp100" type="number" class="form-control" disabled></td>
                <td><input id="dimancheRTT" type="number" class="form-control" disabled></td>
            </tr>
        </tbody>
    </table>

    <div class="row">
        <h4>Total heures semaine :</h4>
        <div class="col-1">
            <input id="totalHsaisie" class="form-control" disabled>
        </div>
    </div>
</div>

{% block javascripts %}
<script src="{{ asset('js/calculette.js') }}"></script>
<script>
// === Gestion du switch permanent / non permanent ===
let apiPrefix = "nonpermanent";

// === Gestion saisonnier ===
function toggleSaisonnierMode(isSaisonnier) {
    const repCompSelectors = [
        'HRepComp','HRepComp10','HRepComp25','HRepComp50','HRepComp100'
    ];
    const jours = ['lundi','mardi','mercredi','jeudi','vendredi','samedi','dimanche'];
    jours.forEach(jour => {
        repCompSelectors.forEach(suffix => {
            const input = document.getElementById(`${jour}${suffix}`);
            if (input) {
                if (isSaisonnier) {
                    input.value = null;
                    input.disabled = true;
                } else {
                    input.disabled = false;
                }
            }
        });
    });
}

document.getElementById("permanentSwitch").addEventListener("change", function() {
    apiPrefix = this.checked ? "permanent" : "nonpermanent";

    const saisonnier = document.getElementById("saisonnierCheckbox");
    if (this.checked) {
        saisonnier.checked = false;
        toggleSaisonnierMode(false);
    } else {
        saisonnier.checked = true;
        toggleSaisonnierMode(true);
    }
    calcul();
});

document.getElementById('saisonnierCheckbox').addEventListener('change', function() {
    toggleSaisonnierMode(this.checked);
    calcul();
});

document.addEventListener('DOMContentLoaded', function() {
    toggleSaisonnierMode(document.getElementById('saisonnierCheckbox').checked);
});
</script>
{% endblock %}

<!-- Inclure Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

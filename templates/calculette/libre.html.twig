<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calculette Libre</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

{% include 'navbar.html.twig' %}

<div class="modal fade" id="alertModal" tabindex="-1" aria-labelledby="alertModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="alertModalLabel">Alerte</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Le total des heures saisies dépasse 60h. Veuillez vérifier votre saisie.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">OK</button>
            </div>
        </div>
    </div>
</div>

<div class="container mt-5">
    <div class="form-check form-switch mb-3">
        <input class="form-check-input" type="checkbox" id="permanentSwitch">
        <label class="form-check-label" for="permanentSwitch">Permanent</label>
    </div>

    <div class="form-check mb-3">
        <input class="form-check-input" type="checkbox" value="" id="saisonnierCheckbox" checked>
        <label class="form-check-label" for="saisonnierCheckbox">
            Saisonnier
        </label>
    </div>

    <h2 class="mt-4 mb-4" id="tableau-heures">Calculette libre</h2>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th></th>
                <th style="width: 50px;">H. effectuée</th>
                <th>H. Norm.</th>
                <th>H. rep. comp.</th>
                <th>H. compl.</th>
                <th>HS 10%</th>
                <th>H. rep. comp. 10%</th>
                <th>HS 25% de 36 à 43</th>
                <th>H. rep. comp. 25%</th>
                <th>HS 50% + de 43</th>
                <th>H. rep. comp. 50%</th>
                <th>HS 100%</th>
                <th>H. rep. comp. 100%</th>
                <th>RTT</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td style="white-space: nowrap;">Lundi</td>
                <td><input id="lundiHSaisie" type="number" class="form-control HSaisie" onKeyUp="calcul()"></td>
                <td><input id="lundiHNorm" type="number" class="form-control HNorm" disabled></td>
                <td><input id="lundiHRepComp" type="number" class="form-control HRepComp" disabled></td>
                <td><input id="lundiHCompl" type="number" class="form-control HCompl" disabled></td>
                <td><input id="lundiHS10" type="number" class="form-control" disabled></td>
                <td><input id="lundiHRepComp10" type="number" class="form-control" disabled></td>
                <td><input id="lundiHS25" type="number" class="form-control HS25" disabled></td>
                <td><input id="lundiHRepComp25" type="number" class="form-control" disabled></td>
                <td><input id="lundiHS50" type="number" class="form-control HS50" disabled></td>
                <td><input id="lundiHRepComp50" type="number" class="form-control" disabled></td>
                <td><input id="lundiHS100" type="number" class="form-control" disabled></td>
                <td><input id="lundiHRepComp100" type="number" class="form-control" disabled></td>
                <td><input id="lundiRTT" type="number" class="form-control" disabled></td>
            </tr>
            <tr>
                <td style="white-space: nowrap;">Mardi</td>
                <td><input id="mardiHSaisie" type="number" class="form-control HSaisie" onKeyUp="calcul()"></td>
                <td><input id="mardiHNorm" type="number" class="form-control HNorm" disabled></td>
                <td><input id="mardiHRepComp" type="number" class="form-control HRepComp" disabled></td>
                <td><input id="mardiHCompl" type="number" class="form-control HCompl" disabled></td>
                <td><input id="mardiHS10" type="number" class="form-control" disabled></td>
                <td><input id="mardiHRepComp10" type="number" class="form-control" disabled></td>
                <td><input id="mardiHS25" type="number" class="form-control HS25" disabled></td>
                <td><input id="mardiHRepComp25" type="number" class="form-control" disabled></td>
                <td><input id="mardiHS50" type="number" class="form-control HS50" disabled></td>
                <td><input id="mardiHRepComp50" type="number" class="form-control" disabled></td>
                <td><input id="mardiHS100" type="number" class="form-control" disabled></td>
                <td><input id="mardiHRepComp100" type="number" class="form-control" disabled></td>
                <td><input id="mardiRTT" type="number" class="form-control" disabled></td>
            </tr>
            <tr>
                <td style="white-space: nowrap;">Mercredi</td>
                <td><input id="mercrediHSaisie" type="number" class="form-control HSaisie" onKeyUp="calcul()"></td>
                <td><input id="mercrediHNorm" type="number" class="form-control HNorm" disabled></td>
                <td><input id="mercrediHRepComp" type="number" class="form-control HRepComp" disabled></td>
                <td><input id="mercrediHCompl" type="number" class="form-control HCompl" disabled></td>
                <td><input id="mercrediHS10" type="number" class="form-control" disabled></td>
                <td><input id="mercrediHRepComp10" type="number" class="form-control" disabled></td>
                <td><input id="mercrediHS25" type="number" class="form-control HS25" disabled></td>
                <td><input id="mercrediHRepComp25" type="number" class="form-control" disabled></td>
                <td><input id="mercrediHS50" type="number" class="form-control HS50" disabled></td>
                <td><input id="mercrediHRepComp50" type="number" class="form-control" disabled></td>
                <td><input id="mercrediHS100" type="number" class="form-control" disabled></td>

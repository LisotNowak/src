{% extends 'base.html.twig' %}
{% block title %}Gestion Point{% endblock %}

{% block sidebar %}
    {% include 'dotation/sidebar.html.twig' with {'active_link': 'GestionPoint'} %}
{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <style>
        .legend-box { display:inline-block; width:14px; height:14px; margin-right:6px; border:1px solid #ccc; vertical-align:middle; }
    </style>

    <div class="d-flex align-items-center justify-content-between mb-4">
        <h2 class="mb-0">Gestion des points utilisateurs</h2>
        <button class="btn btn-warning" data-bs-toggle="modal" data-bs-target="#modalJamaisConnectes">
            <i class="bi bi-person-exclamation me-1"></i>
            Jamais connectés ({{ usersJamaisConnectes|length }})
        </button>
    </div>

    <!-- Modal : utilisateurs jamais connectés avec ROLE_USER_DOTA -->
    <div class="modal fade" id="modalJamaisConnectes" tabindex="-1" aria-labelledby="modalJamaisConnectesLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalJamaisConnectesLabel">
                        Utilisateurs jamais connectés avec droit de commande
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body">
                    {% if usersJamaisConnectes is empty %}
                        <div class="alert alert-success mb-0">Tous les utilisateurs se sont déjà connectés.</div>
                    {% else %}
                        <p class="text-muted small">Ces utilisateurs possèdent <strong>ROLE_USER_DOTA</strong> mais n'ont jamais changé leur mot de passe (première connexion non effectuée).</p>
                        <table class="table table-sm table-bordered align-middle">
                            <thead class="table-dark">
                                <tr>
                                    <th>Nom</th>
                                    <th>Prénom</th>
                                    <th>Email</th>
                                    <th>Service</th>
                                    <th>Section</th>
                                    <th>Points</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for u in usersJamaisConnectes %}
                                    <tr>
                                        <td>{{ u.nom }}</td>
                                        <td>{{ u.prenom }}</td>
                                        <td>{{ u.email }}</td>
                                        <td>{{ u.service }}</td>
                                        <td>{{ u.section }}</td>
                                        <td class="text-center">{{ u.pointDotation ?? 0 }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    {% endif %}
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fermer</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Légende -->
    <div class="mb-3">
        <span class="legend-box" style="background-color:#d4edda;border-color:#c3e6cb;"></span> Utilisateur avec ROLE_USER_DOTA
    </div>

    <!-- Filtres -->
    <div class="row mb-4">
        <div class="col-md-4">
            <label for="filterService" class="form-label">Filtrer par Service</label>
            <select id="filterService" class="form-select" onchange="onServiceChange()">
                <option value="">-- Tous les services --</option>
                {% for service in services %}
                    {% if service %}
                        <option value="{{ service }}">{{ service }}</option>
                    {% endif %}
                {% endfor %}
            </select>
        </div>
        <div class="col-md-4">
            <label for="filterSection" class="form-label">Filtrer par Section</label>
            <select id="filterSection" class="form-select" onchange="applyFilters()" disabled>
                <option value="">-- Toutes les sections --</option>
            </select>
        </div>
        <div class="col-md-4 d-flex align-items-end">
            <div class="me-2">
                <button class="btn btn-secondary" onclick="resetFilters()">
                    <i class="bi bi-arrow-clockwise"></i> Réinitialiser
                </button>
            </div>

            <!-- Boutons pour donner / retirer ROLE_USER_DOTA au service sélectionné -->
            <div>
                <button id="btnGrantRole" class="btn btn-primary me-1" onclick="setRoleForService('grant')" disabled>
                    <i class="bi bi-person-plus"></i> Donner ROLE_USER_DOTA
                </button>
                <button id="btnRevokeRole" class="btn btn-danger mt-2" onclick="setRoleForService('revoke')" disabled>
                    <i class="bi bi-person-x"></i> Retirer ROLE_USER_DOTA
                </button>
            </div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle text-center">
            <thead class="table-dark">
                <tr>
                    <th scope="col">Nom</th>
                    <th scope="col">Prenom</th>
                    <th scope="col">Email</th>
                    <th scope="col">Points</th>
                    <th scope="col">Contrat</th>
                    <th scope="col">Durée</th>
                    <th scope="col">Service</th>
                    <th scope="col">Section</th>
                    <th scope="col">Date début contrat</th>
                    <th scope="col">Date fin contrat</th>
                    <th scope="col">Action</th>
                </tr>
            </thead>
            <tbody id="userTableBody">
                {% for user in listeUsers %}
                    {% set hasRole = 'ROLE_USER_DOTA' in user.getRoles()|join(',') %}
                    {% set bg = hasRole ? 'background-color:#d4edda !important;' : '' %}

                    <tr class="user-row"
                        data-service="{{ user.service }}"
                        data-section="{{ user.section }}"
                    >

                        <td style="{{ bg }}">{{ user.nom }}</td>
                        <td style="{{ bg }}">{{ user.prenom }}</td>
                        <td style="{{ bg }}">{{ user.email }}</td>

                        <td style="width: 120px; {{ bg }}">
                            <input type="number" 
                                value="{{ user.pointDotation }}" 
                                id="points-{{ user.id }}" 
                                class="form-control text-center">
                        </td>

                        <td style="{{ bg }}">{{ user.contract }}</td>

                        <td style="{{ bg }}">
                            {% if user.dateDebutContrat and not user.dateFinContrat %}
                                CDI
                            {% elseif user.dateDebutContrat and user.dateFinContrat %}
                                {% set start = user.dateDebutContrat %}
                                {% set end = user.dateFinContrat %}
                                {% set years = end|date('Y') - start|date('Y') %}
                                {% set months = end|date('m') - start|date('m') %}
                                {% if months < 0 %}
                                    {% set years = years - 1 %}
                                    {% set months = months + 12 %}
                                {% endif %}
                                {{ years }} ans {% if months > 0 %}{{ months }} mois{% endif %}
                            {% else %}
                                -
                            {% endif %}
                        </td>

                        <td style="{{ bg }}">{{ user.service|raw }}</td>
                        <td style="{{ bg }}">{{ user.section|raw }}</td>

                        <td style="{{ bg }}">
                            <input type="date"
                                value="{{ user.dateDebutContrat ? user.dateDebutContrat|date('Y-m-d') : '' }}"
                                id="dateDebut-{{ user.id }}"
                                class="form-control text-center">
                        </td>

                        <td style="{{ bg }}">
                            <input type="date"
                                value="{{ user.dateFinContrat ? user.dateFinContrat|date('Y-m-d') : '' }}"
                                id="dateFin-{{ user.id }}"
                                class="form-control text-center">
                        </td>

                        <td style="{{ bg }}">
                            <button class="btn btn-success btn-sm" 
                                    onclick="updateUserData({{ user.id }})">
                                <i class="bi bi-save"></i> Sauvegarder
                            </button>
                        </td>
                    </tr>
                {% else %}
                    <tr id="noResultsRow">
                        <td colspan="11" class="text-muted">Aucun utilisateur trouvé.</td>
                    </tr>
                {% endfor %}
            </tbody>

        </table>
    </div>
</div>

<script>
// Map des sections par service (généré depuis PHP)
const sectionsByService = {
    {% for service, sectionList in servicesSections %}
        "{{ service|escape('js') }}": [{% for section in sectionList %}"{{ section|escape('js') }}"{{ not loop.last ? ',' : '' }}{% endfor %}],
    {% endfor %}
};

function onServiceChange() {
    const serviceSelect = document.getElementById('filterService');
    const sectionSelect = document.getElementById('filterSection');
    const selectedService = serviceSelect.value;

    // Réinitialiser le select section
    sectionSelect.innerHTML = '<option value="">-- Toutes les sections --</option>';

    if (selectedService === '') {
        // Aucun service sélectionné
        sectionSelect.disabled = true;
    } else {
        // Remplir les sections du service sélectionné
        const sections = sectionsByService[selectedService] || [];
        sections.forEach(section => {
            const option = document.createElement('option');
            option.value = section;
            option.textContent = section;
            sectionSelect.appendChild(option);
        });
        sectionSelect.disabled = false;
    }

    applyFilters();
    updateServiceRoleButtons(); // <-- mise à jour des boutons
}

function applyFilters() {
    const service = document.getElementById('filterService').value;
    const section = document.getElementById('filterSection').value;
    const rows = document.querySelectorAll('.user-row');
    let visibleCount = 0;

    rows.forEach(row => {
        const rowService = row.getAttribute('data-service');
        const rowSection = row.getAttribute('data-section');

        const matchService = !service || rowService === service;
        const matchSection = !section || rowSection === section;

        if (matchService && matchSection) {
            row.style.display = '';
            visibleCount++;
        } else {
            row.style.display = 'none';
        }
    });

    const noResultsRow = document.getElementById('noResultsRow');
    if (noResultsRow) {
        noResultsRow.style.display = visibleCount === 0 ? '' : 'none';
    }

    updateServiceRoleButtons(); // <-- mise à jour des boutons après filtrage
}

function resetFilters() {
    document.getElementById('filterService').value = '';
    document.getElementById('filterSection').value = '';
    document.getElementById('filterSection').disabled = true;
    document.getElementById('filterSection').innerHTML = '<option value="">-- Toutes les sections --</option>';
    applyFilters();
    updateServiceRoleButtons(); // <-- mise à jour des boutons
}

// nouveau : active/désactive boutons selon règles : un service sélectionné ET aucune section sélectionnée
function updateServiceRoleButtons() {
    const service = document.getElementById('filterService').value;
    const section = document.getElementById('filterSection').value;
    const btnGrant = document.getElementById('btnGrantRole');
    const btnRevoke = document.getElementById('btnRevokeRole');

    const enabled = (service !== '') && (section === '');
    if (btnGrant) btnGrant.disabled = !enabled;
    if (btnRevoke) btnRevoke.disabled = !enabled;
}

// appeler au chargement pour initialiser l'état des boutons
document.addEventListener('DOMContentLoaded', function() {
    updateServiceRoleButtons();
});

function updateUserData(userId) {
    const points = document.getElementById('points-' + userId).value;
    const dateDebut = document.getElementById('dateDebut-' + userId).value;
    const dateFin = document.getElementById('dateFin-' + userId).value;

    fetch('{{ path("admin_update_points") }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            user_id: userId,
            points: points,
            date_debut: dateDebut,
            date_fin: dateFin
        })
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            alert("✅ Données mises à jour !");
        } else {
            alert("❌ Erreur : " + data.message);
        }
    })
    .catch(() => alert("⚠️ Erreur de communication avec le serveur."));
}

// token CSRF pour les actions de rôle par service
const csrfToken = '{{ csrf_token("service_role_action") }}';

function setRoleForService(action) {
    const service = document.getElementById('filterService').value;
    if (!service) {
        alert('Sélectionnez d\'abord un service.');
        return;
    }
    const confirmMsg = action === 'grant'
        ? `Donner ROLE_USER_DOTA à tous les utilisateurs du service "${service}" ?`
        : `Retirer ROLE_USER_DOTA à tous les utilisateurs du service "${service}" ?`;
    if (!confirm(confirmMsg)) return;

    fetch('{{ path("app_dota_service_role") }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            service: service,
            action: action,
            _csrf_token: csrfToken
        })
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            alert(`Opération réussie — utilisateurs modifiés : ${data.modified}`);
            // Recharger la page pour actualiser l'affichage
            location.reload();
        } else {
            alert('Erreur : ' + (data.message || 'erreur inconnue'));
        }
    })
    .catch(() => alert('Erreur réseau en contactant le serveur.'));
}
</script>
{% endblock %}

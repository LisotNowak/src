{% extends 'base.html.twig' %}

{% block title %}Mes demandes d'échange{% endblock %}

{% block sidebar %}
    {% include 'dotation/sidebar.html.twig' with {'active_link': 'mes_demandes_echange'} %}
{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1>Mes demandes d'échange</h1>

    {% if demandes is empty %}
        <div class="alert alert-info">Vous n'avez aucune demande d'échange.</div>
    {% else %}
        {% for entry in demandes %}
            {% set demande = entry.demande %}
            <div class="card mb-3">
                <div class="card-header">
                    <strong>Demande #{{ demande.id }}</strong>
                    <span class="float-end">{{ demande.dateDemande|date('d/m/Y H:i') }}</span>
                    <div class="small text-muted">
                        Statut : 
                        {% if demande.status == 'En attente' %}
                            <span class="badge bg-warning text-dark">{{ demande.status }}</span>
                        {% elseif demande.status == 'Approuvée' %}
                            <span class="badge bg-success">{{ demande.status }}</span>
                        {% elseif demande.status == 'Refusée' %}
                            <span class="badge bg-danger">{{ demande.status }}</span>
                        {% else %}
                            <span class="badge bg-secondary">{{ demande.status }}</span>
                        {% endif %}
                    </div>

                </div>
                <div class="card-body">
                    <table class="table table-sm mb-3">
                        <thead>
                            <tr>
                                <th>Ancien article</th>
                                <th>Nouvel article</th>
                                <th>Raison</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>
                                    {% if entry.oldArticle %}
                                        <strong>{{ entry.oldArticle.nom }}</strong><br>
                                        <span class="text-muted small">[{{ entry.oldArticle.reference }}]</span><br>
                                        Taille : {{ entry.oldAssoc.taille.nom|default('') }}<br>
                                        Couleur : {{ entry.oldAssoc.couleur.nom|default('') }}<br>
                                        Qté retournée : {{ demande.quantite ?? 1 }}
                                    {% else %}
                                        Article supprimé
                                    {% endif %}
                                </td>
                                <td>
                                    {% if entry.newArticle %}
                                        <strong>{{ entry.newArticle.nom }}</strong><br>
                                        <span class="text-muted small">[{{ entry.newArticle.reference }}]</span><br>
                                        Taille : {{ demande.newTaille }}<br>
                                        Couleur : {{ demande.newCouleur }}<br>
                                        Qté souhaitée : {{ demande.quantiteNew ?? 1 }}
                                    {% else %}
                                        Article supprimé
                                    {% endif %}
                                </td>
                                <td>{{ demande.reason }}</td>
                            </tr>
                        </tbody>
                    </table>

                    {# Bilan de points #}
                    {% if entry.oldArticle and entry.newArticle %}
                        {% set ptOld = (entry.oldArticle.point ?? 0) * (demande.quantite ?? 1) %}
                        {% set ptNew = (entry.newArticle.point ?? 0) * (demande.quantiteNew ?? 1) %}
                        {% set result = ptOld - ptNew %}
                        <div class="d-flex align-items-center gap-3 flex-wrap border-top pt-3">
                            <div class="text-center">
                                <div class="text-muted small">Points rendus</div>
                                <div class="fw-bold text-success fs-5">{{ ptOld }} P</div>
                            </div>
                            <div class="text-muted fs-4">−</div>
                            <div class="text-center">
                                <div class="text-muted small">Points demandés</div>
                                <div class="fw-bold text-primary fs-5">{{ ptNew }} P</div>
                            </div>
                            <div class="text-muted fs-4">=</div>
                            <div class="text-center">
                                {% if result > 0 %}
                                    <div class="text-muted small">Crédités</div>
                                    <span class="badge bg-success fs-6">+{{ result }} P</span>
                                {% elseif result < 0 %}
                                    <div class="text-muted small">Retirés</div>
                                    <span class="badge bg-danger fs-6">{{ result }} P</span>
                                {% else %}
                                    <div class="text-muted small">&nbsp;</div>
                                    <span class="badge bg-secondary fs-6">Échange neutre</span>
                                {% endif %}
                                {% if demande.status == 'Refusée' and result != 0 %}
                                    <div class="small text-muted mt-1">
                                        {% if result > 0 %}({{ result }} P repris){% else %}({{ result|abs }} P recrédités){% endif %}
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    {% endif %}
</div>
{% endblock %}

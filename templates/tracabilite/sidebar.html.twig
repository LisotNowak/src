<style>
    /* ── Layout plein-écran sans scrollbar navigateur ────────────────────── */
    html, body {
        height: 100%;
        overflow: hidden;
    }
    body {
        display: flex !important;
        flex-direction: column;
    }
    #app-wrapper {
        flex: 1;
        min-height: 0;        /* permet à flex de réduire sous son contenu */
        overflow: hidden;
        display: flex !important;
    }
    #main-content {
        flex: 1;
        min-height: 0;
        overflow-y: auto;
        overflow-x: hidden;
    }
    /* ─────────────────────────────────────────────────────────────────────── */

    .sidebar-tracabilite {
        width: 220px;
        background-color: #f8f9fa;
        border-right: 1px solid #dee2e6;
        padding: 1rem 0;
        flex-shrink: 0;
        overflow-y: auto;   /* scroll interne si beaucoup d'items */
    }
    .sidebar-tracabilite .sidebar-title {
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        color: #6c757d;
        text-transform: uppercase;
        padding: 0.5rem 1.2rem 0.25rem;
    }
    .sidebar-tracabilite .nav-link {
        color: #343a40;
        padding: 0.5rem 1.2rem;
        border-radius: 0;
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-size: 0.9rem;
    }
    .sidebar-tracabilite .nav-link:hover { background-color: #e9ecef; color: #800000; }
    .sidebar-tracabilite .nav-link.active { background-color: #800000; color: #fff; font-weight: 600; }
    .sidebar-tracabilite .nav-link.active i { color: #fff; }
    .sidebar-tracabilite i { width: 16px; text-align: center; color: #800000; }

    .offcanvas-tracabilite .sidebar-title {
        font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em;
        color: #6c757d; text-transform: uppercase;
        padding: 0.5rem 1.2rem 0.25rem;
    }
    .offcanvas-tracabilite .nav-link {
        color: #343a40; padding: 0.6rem 1.2rem;
        display: flex; align-items: center; gap: 0.6rem; font-size: 1rem;
    }
    .offcanvas-tracabilite .nav-link:hover { background-color: #e9ecef; color: #800000; }
    .offcanvas-tracabilite .nav-link.active { background-color: #800000; color: #fff; font-weight: 600; }
    .offcanvas-tracabilite .nav-link.active i { color: #fff; }
    .offcanvas-tracabilite i { width: 18px; text-align: center; color: #800000; }

    .mobile-bottombar-trac {
        display: none;
        position: fixed;
        bottom: 0; left: 0; right: 0;
        background: #800000;
        z-index: 1030;
        padding: 6px 0;
        box-shadow: 0 -2px 8px rgba(0,0,0,0.2);
    }
    .mobile-bottombar-trac a {
        color: rgba(255,255,255,0.7);
        text-decoration: none;
        font-size: 0.7rem;
        display: flex; flex-direction: column; align-items: center; gap: 2px;
        flex: 1;
        padding: 4px 0;
    }
    .mobile-bottombar-trac a.active { color: #fff; }
    .mobile-bottombar-trac a i { font-size: 1.2rem; }

    @media (max-width: 991px) {
        .sidebar-tracabilite    { display: none !important; }
        .mobile-bottombar-trac  { display: flex !important; }
        /* Le padding va sur #main-content pour que le scroll interne l'inclue */
        body { padding-bottom: 0 !important; }
        #main-content { padding-bottom: 70px; }
    }
</style>


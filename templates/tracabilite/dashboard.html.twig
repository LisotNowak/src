{% extends 'tracabilite/layout.html.twig' %}

{% block title %}Tracabilité – Tableau de bord{% endblock %}

{% block body %}
<div class="p-3 p-lg-4">

    {# Flash messages #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'success' ? 'success' : (label == 'danger' ? 'danger' : 'info') }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {# En-tête + sélecteur de mois #}
    <div class="d-flex flex-wrap align-items-center justify-content-between mb-4 gap-2">
        <h4 class="mb-0 fw-bold" style="color:#800000;">
            <i class="fas fa-tachometer-alt me-2"></i>Tableau de bord
        </h4>
        <form method="get" class="d-flex align-items-center gap-2">
            <label class="form-label mb-0 text-muted small">Mois :</label>
            <input type="month" name="mois" value="{{ mois }}" class="form-control form-control-sm" style="width:160px;" onchange="this.form.submit()">
        </form>
    </div>

    {# KPIs #}
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="fs-2 fw-bold" style="color:#800000;">{{ kpis.nbSaisies ?? 0 }}</div>
                    <div class="text-muted small">Saisies ce mois</div>
                    <i class="fas fa-pen-square fa-lg mt-1" style="color:#800000; opacity:0.3;"></i>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="fs-2 fw-bold" style="color:#800000;">{{ kpis.totalHeures ? kpis.totalHeures|number_format(1, ',', ' ') : '0' }}</div>
                    <div class="text-muted small">Heures travaillées</div>
                    <i class="fas fa-clock fa-lg mt-1" style="color:#800000; opacity:0.3;"></i>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="fs-2 fw-bold" style="color:#800000;">{{ kpis.nbParcelles ?? 0 }}</div>
                    <div class="text-muted small">Parcelles travaillées</div>
                    <i class="fas fa-leaf fa-lg mt-1" style="color:#800000; opacity:0.3;"></i>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="fs-2 fw-bold" style="color:#800000;">{{ equipes|length }}</div>
                    <div class="text-muted small">Équipes actives</div>
                    <i class="fas fa-users fa-lg mt-1" style="color:#800000; opacity:0.3;"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        {# Saisies récentes #}
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold d-flex align-items-center justify-content-between">
                    <span><i class="fas fa-pen-square me-2" style="color:#800000;"></i>Saisies récentes</span>
                    <a href="{{ path('app_tracabilite_saisie_new') }}" class="btn btn-sm btn-outline-success">
                        <i class="fas fa-plus me-1"></i>Nouvelle saisie
                    </a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Date</th>
                                    <th>Chef</th>
                                    <th class="d-none d-md-table-cell">Personnel</th>
                                    <th class="d-none d-sm-table-cell">Tâche</th>
                                    <th class="d-none d-sm-table-cell">Parcelle</th>
                                    <th class="text-end">Avanc.</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for s in recentes %}
                                <tr>
                                    <td class="text-nowrap small">
                                        {{ s.dateTravail|date('d/m/Y') }}
                                        <div class="d-sm-none text-muted" style="font-size:0.7rem;">{{ s.tacheNom|slice(0,20) }}</div>
                                    </td>
                                    <td><span class="badge text-bg-secondary">{{ s.chefNom }}</span></td>
                                    <td class="small d-none d-md-table-cell">{{ s.personnelNom }}</td>
                                    <td class="small text-truncate d-none d-sm-table-cell" style="max-width:120px;">{{ s.tacheNom }}</td>
                                    <td class="small text-muted d-none d-sm-table-cell">{{ s.parcelleNom ?? '—' }}</td>
                                    <td class="text-end">
                                        {% if s.avancement > 0 %}
                                            <span class="badge {% if s.avancement >= 100 %}text-bg-success{% elseif s.avancement >= 50 %}text-bg-info{% else %}text-bg-warning{% endif %}">
                                                {{ s.avancement|number_format(0) }}%
                                            </span>
                                        {% else %}—{% endif %}
                                    </td>
                                </tr>
                                {% else %}
                                <tr><td colspan="6" class="text-center text-muted py-3">Aucune saisie pour ce mois</td></tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
                {% if recentes|length > 0 %}
                <div class="card-footer bg-white text-center">
                    <a href="{{ path('app_tracabilite_saisie_index', {mois: mois}) }}" class="small text-muted">
                        Voir toutes les saisies <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
                {% endif %}
            </div>
        </div>

        {# Parcelles non terminées #}
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white fw-semibold">
                    <i class="fas fa-exclamation-circle me-2 text-warning"></i>Travaux en cours
                    <span class="badge text-bg-warning ms-2">{{ nonTerminees|length }}</span>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush" style="max-height:380px; overflow-y:auto;">
                        {% for item in nonTerminees %}
                        <div class="list-group-item list-group-item-action py-2 px-3">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="small">
                                    <div class="fw-semibold">{{ item.parcelleNom }}</div>
                                    <div class="text-muted">{{ item.tacheNom }}</div>
                                    <div class="text-muted" style="font-size:0.75rem;">Chef : {{ item.chefNom }}</div>
                                </div>
                                <div class="text-end ms-2">
                                    <div class="fw-bold {% if item.maxAdv >= 75 %}text-info{% elseif item.maxAdv >= 50 %}text-warning{% else %}text-danger{% endif %}">
                                        {{ item.maxAdv|number_format(0) }}%
                                    </div>
                                    <div class="text-muted" style="font-size:0.7rem;">{{ item.dernierDate|date('d/m') }}</div>
                                </div>
                            </div>
                            <div class="progress mt-1" style="height:4px;">
                                <div class="progress-bar {% if item.maxAdv >= 75 %}bg-info{% elseif item.maxAdv >= 50 %}bg-warning{% else %}bg-danger{% endif %}"
                                     style="width:{{ item.maxAdv }}%;"></div>
                            </div>
                        </div>
                        {% else %}
                        <div class="list-group-item text-center text-muted py-3">
                            <i class="fas fa-check-circle text-success me-1"></i>Tous les travaux sont terminés
                        </div>
                        {% endfor %}
                    </div>
                </div>
                {% if nonTerminees|length > 0 %}
                <div class="card-footer bg-white text-center">
                    <a href="{{ path('app_tracabilite_avancement', {mois: mois}) }}" class="small text-muted">
                        Voir l'avancement complet <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
                {% endif %}
            </div>
        </div>
    </div>

</div>
{% endblock %}

{% extends 'tracabilite/layout.html.twig' %}

{% block title %}Tracabilité – Saisies{% endblock %}

{% block body %}
<div class="p-2 p-md-3 p-lg-4">

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'success' ? 'success' : (label == 'danger' ? 'danger' : 'info') }} alert-dismissible fade show py-2 small">
                {{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="d-flex flex-wrap align-items-center justify-content-between mb-2 gap-2">
        <h5 class="mb-0 fw-bold" style="color:#800000;">
            <i class="fas fa-pen-square me-2"></i>Saisies de travail
        </h5>
        <a href="{{ path('app_tracabilite_saisie_new') }}" class="btn btn-sm btn-success">
            <i class="fas fa-plus me-1"></i><span class="d-none d-sm-inline">Nouvelle saisie</span><span class="d-sm-none">Nouveau</span>
        </a>
    </div>

    {# Filtres #}
    <form method="get" class="card border-0 shadow-sm mb-3">
        <div class="card-body py-2 px-3">
            <div class="row g-2 align-items-end">
                <div class="col-6 col-sm-3 col-md-2">
                    <label class="form-label mb-0 small fw-semibold">Mois</label>
                    <input type="month" name="mois" value="{{ filtres.mois }}" class="form-control form-control-sm" onchange="this.form.submit()">
                </div>
                <div class="col-6 col-sm-3 col-md-3">
                    <label class="form-label mb-0 small fw-semibold">Équipe</label>
                    <select name="chef" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="">Toutes</option>
                        {% for e in equipes %}
                            <option value="{{ e }}" {{ filtres.chef == e ? 'selected' : '' }}>{{ e }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-6 col-sm-3 col-md-3 d-none d-sm-block">
                    <label class="form-label mb-0 small fw-semibold">Tâche</label>
                    <select name="tache" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="">Toutes</option>
                        {% for t in taches %}
                            <option value="{{ t }}" {{ filtres.tache == t ? 'selected' : '' }}>{{ t }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-6 col-sm-2 col-md-3 d-none d-sm-block">
                    <label class="form-label mb-0 small fw-semibold">Parcelle</label>
                    <select name="parcel" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="">Toutes</option>
                        {% for p in parcelles %}
                            <option value="{{ p }}" {{ filtres.parcel == p ? 'selected' : '' }}>{{ p }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>
        </div>
    </form>

    {# Tableau #}
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center py-2">
            <span class="small text-muted">{{ saisies|length }} résultat(s)</span>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th class="d-none d-sm-table-cell">Équipe</th>
                        <th class="d-none d-md-table-cell">Personnel</th>
                        <th class="d-none d-sm-table-cell">Tâche</th>
                        <th class="d-none d-md-table-cell">Parcelle</th>
                        <th class="text-center d-none d-lg-table-cell">Heures</th>
                        <th class="text-center d-none d-lg-table-cell">Effect.</th>
                        <th class="text-center">Avanc.</th>
                        <th class="text-center d-none d-lg-table-cell">Pieds</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for s in saisies %}
                    <tr class="{{ s.type == 'RH' ? 'table-light' : '' }}">
                        <td class="text-nowrap small">
                            {{ s.dateTravail|date('d/m/Y') }}
                            {# Sur mobile, affiche tâche sous la date #}
                            <div class="d-sm-none text-muted" style="font-size:0.7rem; max-width:120px; overflow:hidden; white-space:nowrap; text-overflow:ellipsis;">
                                {{ s.tacheNom }}
                            </div>
                        </td>
                        <td class="d-none d-sm-table-cell">
                            <span class="badge text-bg-secondary">{{ s.chefNom }}</span>
                        </td>
                        <td class="small d-none d-md-table-cell">
                            {{ s.personnelNom }}
                            {% if s.effectif > 1 %}<span class="badge text-bg-info ms-1">×{{ s.effectif }}</span>{% endif %}
                        </td>
                        <td class="small d-none d-sm-table-cell" style="max-width:160px;">
                            <span class="d-inline-block text-truncate" style="max-width:150px;" title="{{ s.tacheNom }}">{{ s.tacheNom }}</span>
                            {% if s.type == 'RH' %}<span class="badge text-bg-warning ms-1">RH</span>{% endif %}
                        </td>
                        <td class="small text-muted d-none d-md-table-cell" style="max-width:130px;">
                            <span class="d-inline-block text-truncate" style="max-width:120px;" title="{{ s.parcelleNom ?? '' }}">{{ s.parcelleNom ?? '—' }}</span>
                        </td>
                        <td class="text-center small d-none d-lg-table-cell">{{ s.heures|number_format(2, ',') }}h</td>
                        <td class="text-center small d-none d-lg-table-cell">{{ s.effectif }}</td>
                        <td class="text-center">
                            {% if s.type == 'Terrain' %}
                                <span class="badge {% if s.avancement >= 100 %}text-bg-success{% elseif s.avancement >= 50 %}text-bg-info{% elseif s.avancement > 0 %}text-bg-warning{% else %}text-bg-light text-dark{% endif %}">
                                    {{ s.avancement|number_format(0) }}%
                                </span>
                            {% else %}<span class="text-muted small">—</span>{% endif %}
                        </td>
                        <td class="text-center small d-none d-lg-table-cell">{{ s.pieds > 0 ? s.pieds|number_format(0, ',', ' ') : '—' }}</td>
                        <td class="text-center text-nowrap">
                            <a href="{{ path('app_tracabilite_saisie_edit', {id: s.id}) }}"
                               class="btn btn-xs btn-outline-primary" style="padding:2px 7px; font-size:0.75rem;">
                                <i class="fas fa-edit"></i>
                            </a>
                            <button type="button" class="btn btn-xs btn-outline-danger ms-1"
                                    style="padding:2px 7px; font-size:0.75rem;"
                                    data-bs-toggle="modal" data-bs-target="#delModal{{ loop.index }}">
                                <i class="fas fa-trash"></i>
                            </button>
                        </td>
                    </tr>

                    {# Modal suppression #}
                    <div class="modal fade" id="delModal{{ loop.index }}" tabindex="-1">
                        <div class="modal-dialog modal-sm">
                            <div class="modal-content">
                                <div class="modal-header py-2" style="background:#800000; color:#fff;">
                                    <h6 class="modal-title">Confirmer la suppression</h6>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body small">
                                    <strong>{{ s.dateTravail|date('d/m/Y') }}</strong> – {{ s.personnelNom }}<br>
                                    {{ s.tacheNom }}{% if s.parcelleNom %} / {{ s.parcelleNom }}{% endif %}
                                </div>
                                <div class="modal-footer py-2">
                                    <button class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Annuler</button>
                                    <form action="{{ path('app_tracabilite_saisie_delete', {id: s.id}) }}" method="post">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_saisie_' ~ s.id) }}">
                                        <button type="submit" class="btn btn-sm btn-danger">Supprimer</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                    {% else %}
                    <tr><td colspan="10" class="text-center text-muted py-4">Aucune saisie trouvée</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

</div>
{% endblock %}

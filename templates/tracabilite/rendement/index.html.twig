{% extends 'tracabilite/layout.html.twig' %}

{% block title %}Tracabilité – Rendement{% endblock %}

{% block body %}
<div class="p-3 p-lg-4">

    <div class="d-flex flex-wrap align-items-center justify-content-between mb-3 gap-2">
        <h4 class="mb-0 fw-bold" style="color:#800000;">
            <i class="fas fa-chart-bar me-2"></i>Rendement par personnel
        </h4>
    </div>

    {# Filtres #}
    <form method="get" class="card border-0 shadow-sm mb-4">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-sm-4">
                    <label class="form-label mb-1 small fw-semibold">Mois</label>
                    <input type="month" name="mois" value="{{ mois }}" class="form-control form-control-sm" onchange="this.form.submit()">
                </div>
                <div class="col-sm-4">
                    <label class="form-label mb-1 small fw-semibold">Équipe</label>
                    <select name="chef" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="">Toutes les équipes</option>
                        {% for e in equipes %}
                            <option value="{{ e.nom }}" {{ chef == e.nom ? 'selected' : '' }}>{{ e.nom }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>
        </div>
    </form>

    {% if rendements|length > 0 %}

    {# Calcul des totaux #}
    {% set totalHeures = 0 %}
    {% set totalPieds = 0 %}
    {% for r in rendements %}
        {% set totalHeures = totalHeures + r.totalHeuresNettes %}
        {% set totalPieds = totalPieds + r.totalPieds %}
    {% endfor %}
    {% set rendMoyen = totalHeures > 0 ? (totalPieds / totalHeures)|round(1) : 0 %}

    {# KPIs #}
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center">
                <div class="card-body py-2">
                    <div class="fs-4 fw-bold" style="color:#800000;">{{ rendements|length }}</div>
                    <div class="text-muted small">Lignes</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center">
                <div class="card-body py-2">
                    <div class="fs-4 fw-bold" style="color:#800000;">{{ totalHeures|number_format(1, ',') }}h</div>
                    <div class="text-muted small">Heures nettes</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center">
                <div class="card-body py-2">
                    <div class="fs-4 fw-bold" style="color:#800000;">{{ totalPieds|number_format(0, ',', ' ') }}</div>
                    <div class="text-muted small">Pieds totaux</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm text-center">
                <div class="card-body py-2">
                    <div class="fs-4 fw-bold" style="color:#800000;">{{ rendMoyen }}</div>
                    <div class="text-muted small">Pieds / heure (moy.)</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white fw-semibold">
            <i class="fas fa-chart-bar me-2" style="color:#800000;"></i>Détail par personne &amp; tâche
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Personnel</th>
                        <th class="d-none d-md-table-cell">Contrat</th>
                        <th class="d-none d-lg-table-cell">Équipe</th>
                        <th class="d-none d-sm-table-cell">Tâche</th>
                        <th class="text-end d-none d-lg-table-cell">H. brutes</th>
                        <th class="text-end">H. nettes</th>
                        <th class="text-end d-none d-md-table-cell">Pieds</th>
                        <th class="text-end">Pieds/h</th>
                    </tr>
                </thead>
                <tbody>
                    {% set lastPersonnel = null %}
                    {% for r in rendements %}
                    <tr class="{{ lastPersonnel and lastPersonnel != r.personnelNom ? 'border-top' : '' }}">
                        <td class="fw-semibold small">
                            {% if lastPersonnel != r.personnelNom %}
                                {{ r.personnelNom }}
                                <div class="d-sm-none text-muted fw-normal" style="font-size:0.7rem;">{{ r.tacheNom }}</div>
                            {% endif %}
                        </td>
                        <td class="d-none d-md-table-cell">
                            {% if lastPersonnel != r.personnelNom %}
                                <span class="badge {% if r.personnelContrat == 'Permanent' %}text-bg-success{% else %}text-bg-warning{% endif %} small">
                                    {{ r.personnelContrat ?? 'N/A' }}
                                </span>
                            {% endif %}
                        </td>
                        <td class="text-muted small d-none d-lg-table-cell">
                            {% if lastPersonnel != r.personnelNom %}<span class="badge text-bg-secondary">{{ r.chefNom }}</span>{% endif %}
                        </td>
                        <td class="small d-none d-sm-table-cell">{{ r.tacheNom }}</td>
                        <td class="text-end small d-none d-lg-table-cell">{{ r.totalHeures ? r.totalHeures|number_format(2, ',') ~ 'h' : '—' }}</td>
                        <td class="text-end small">{{ r.totalHeuresNettes ? r.totalHeuresNettes|number_format(2, ',') ~ 'h' : '—' }}</td>
                        <td class="text-end small d-none d-md-table-cell">{{ r.totalPieds ? r.totalPieds|number_format(0, ',', ' ') : '—' }}</td>
                        <td class="text-end">
                            {% if r.totalHeuresNettes > 0 and r.totalPieds > 0 %}
                                {% set rend = (r.totalPieds / r.totalHeuresNettes)|round(1) %}
                                <span class="badge {% if rend >= 100 %}text-bg-success{% elseif rend >= 60 %}text-bg-info{% else %}text-bg-warning{% endif %}">
                                    {{ rend }}
                                </span>
                            {% else %}—{% endif %}
                        </td>
                    </tr>
                    {% set lastPersonnel = r.personnelNom %}
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {% else %}
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center text-muted py-5">
            <i class="fas fa-chart-bar fa-3x mb-3" style="color:#dee2e6;"></i>
            <div>Aucune donnée de rendement pour ce mois</div>
            <div class="small mt-1">Les données de rendement nécessitent des saisies avec des pieds renseignés</div>
        </div>
    </div>
    {% endif %}

</div>
{% endblock %}
